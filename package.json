{
  "name": "html-native-engine",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/generators/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "npx tsx benchmarks/run.ts",
    "gen-fixtures": "npx tsx benchmarks/fixtures/generate.ts",
    "lint": "eslint packages/",
    "format": "prettier --write 'packages/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
